# ═══════════════════════════════════════════════════════════════════
# 🎭 Configuration Complète du Bot WhatsApp RP avec IA Gemini
# ═══════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────
# 🧠 CONFIGURATION GEMINI AI (OBLIGATOIRE)
# ────────────────────────────────────────────────────────────────────

# Clé API Google Gemini (Obligatoire)
# Obtenir sur: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────────────────────────────────
# 🎭 CONFIGURATION DU BOT RP
# ────────────────────────────────────────────────────────────────────

# Nom du bot affiché dans les messages
# Exemple: 🎭 RP Master Bot, 🤖 CyberGuide, 🌟 AI Storyteller
BOT_NAME=🎭 RP Master Bot

# Univers/monde du jeu de rôle
# Exemple: Cyberpunk 2077, Star Wars, Fantasy Medieval, Sci-Fi
RP_WORLD=Cyberpunk 2077

# Personnage par défaut incarné par l'IA
# Exemple: Assistant IA Futuriste, Sage Magique, Guide Galactique
DEFAULT_CHARACTER=Assistant IA Futuriste

# ────────────────────────────────────────────────────────────────────
# 📸 CONFIGURATION DES MÉDIAS
# ────────────────────────────────────────────────────────────────────

# Dossier racine des médias
MEDIA_FOLDER=./media

# Activer l'envoi automatique de médias (true/false)
ENABLE_MEDIA_RESPONSES=true

# Probabilité d'envoi de média après chaque message (0.0 à 1.0)
# 0.3 = 30% de chance, 0.5 = 50%, etc.
MEDIA_SEND_PROBABILITY=0.3

# ────────────────────────────────────────────────────────────────────
# ⚙️ CONFIGURATION AVANCÉE
# ────────────────────────────────────────────────────────────────────

# Mode debug pour affichage détaillé des logs (true/false)
DEBUG_MODE=false

# Délai avant réponse du bot en millisecondes
# 1000 = 1 seconde, 2000 = 2 secondes, etc.
AUTO_REPLY_DELAY=2000

# Longueur maximale des messages générés par l'IA
# Recommandé: 500-1500 caractères
MAX_MESSAGE_LENGTH=1000

# ────────────────────────────────────────────────────────────────────
# 🎨 CONFIGURATION ESTHÉTIQUE
# ────────────────────────────────────────────────────────────────────

# Préfixe des commandes du bot
COMMAND_PREFIX=!rp

# Style de séparateurs pour les messages
# Options: ═══, ───, ▬▬▬, ◆◇◈, etc.
MESSAGE_SEPARATOR=═══

# Emojis principaux utilisés par le bot
PRIMARY_EMOJI=🎭
SECONDARY_EMOJI=⚡
ACCENT_EMOJI=🔮

# ────────────────────────────────────────────────────────────────────
# 🔒 CONFIGURATION SÉCURITÉ
# ────────────────────────────────────────────────────────────────────

# Nombre maximum de messages dans l'historique par utilisateur
MAX_HISTORY_LENGTH=20

# Limite de caractères par message utilisateur
USER_MESSAGE_LIMIT=2000

# Délai minimum entre messages en millisecondes (anti-spam)
MIN_MESSAGE_INTERVAL=1000

# ────────────────────────────────────────────────────────────────────
# 🚀 CONFIGURATION PERFORMANCE
# ────────────────────────────────────────────────────────────────────

# Timeout pour les requêtes Gemini en millisecondes
GEMINI_TIMEOUT=30000

# Nombre de tentatives en cas d'échec de l'IA
MAX_AI_RETRIES=3

# Intervalle de nettoyage de la mémoire en millisecondes
MEMORY_CLEANUP_INTERVAL=3600000

# ────────────────────────────────────────────────────────────────────
# 🎮 CONFIGURATION FONCTIONNALITÉS AVANCÉES
# ────────────────────────────────────────────────────────────────────

# Activer les réponses automatiques même sans commande RP (true/false)
AUTO_RESPONSE_MODE=false

# Activer la génération de personnages multiples (true/false)
MULTI_CHARACTER_MODE=false

# Activer les quêtes automatiques (true/false)
AUTO_QUEST_MODE=false

# Langue principale des réponses (fr, en, es, etc.)
PRIMARY_LANGUAGE=fr

# ────────────────────────────────────────────────────────────────────
# 📊 CONFIGURATION LOGS ET MONITORING
# ────────────────────────────────────────────────────────────────────

# Niveau de log (error, warn, info, debug)
LOG_LEVEL=info

# Sauvegarder les logs dans un fichier (true/false)
SAVE_LOGS=false

# Dossier des logs
LOG_FOLDER=./logs

# Rotation des logs en jours
LOG_ROTATION_DAYS=7

# ────────────────────────────────────────────────────────────────────
# 🔧 CONFIGURATION DÉVELOPPEMENT
# ────────────────────────────────────────────────────────────────────

# Mode développement (true/false)
DEV_MODE=false

# Afficher les prompts envoyés à l'IA (true/false)
SHOW_AI_PROMPTS=false

# Temps d'attente réduit en mode dev
DEV_REPLY_DELAY=500

# Test mode - ne pas envoyer de vrais messages (true/false)
TEST_MODE=false

# ────────────────────────────────────────────────────────────────────
# 💾 CONFIGURATION BASE DE DONNÉES (FUTUR)
# ────────────────────────────────────────────────────────────────────

# Type de base de données (file, mysql, mongodb)
DB_TYPE=file

# Chemin ou URL de la base de données
DB_PATH=./data/bot.db

# Sauvegarde automatique (true/false)
AUTO_BACKUP=true

# ═══════════════════════════════════════════════════════════════════
# 📝 NOTES D'UTILISATION
# ═══════════════════════════════════════════════════════════════════

# 1. Copiez ce fichier vers .env et modifiez les valeurs
# 2. Seule GEMINI_API_KEY est obligatoire pour le fonctionnement
# 3. Les autres valeurs ont des défauts raisonnables
# 4. Redémarrez le bot après modification
# 5. Utilisez npm run setup pour configuration assistée

# ═══════════════════════════════════════════════════════════════════