{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai_api_key",
    "GOOGLE_SEARCH_API_KEY": "@google_search_api_key",
    "GOOGLE_SEARCH_ENGINE_ID": "@google_search_engine_id"
  }
}