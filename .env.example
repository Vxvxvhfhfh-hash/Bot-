# Configuration du bot WhatsApp Gemini
# IA Google Gemini (OBLIGATOIRE) - Obtenez votre clé sur https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modèle Gemini à utiliser (par défaut: gemini-pro)
GEMINI_MODEL=gemini-pro

# APIs d'images stock (OPTIONNEL)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Configuration du bot
BOT_NAME=Gemini Bot
BOT_PREFIX=!
MAX_MESSAGE_LENGTH=2000

# Configuration des images
ENABLE_IMAGES=true
IMAGE_PROVIDER=unsplash
# Options: unsplash, pexels, random

# Confirmation utilisation exclusive de Gemini (NE PAS MODIFIER)
AI_PROVIDER=gemini_only